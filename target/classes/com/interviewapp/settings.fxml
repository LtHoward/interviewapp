<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.SettingsController">

    <children>
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="TOP_CENTER" fillWidth="true" maxWidth="1050.0" spacing="28.0">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="16.0">
                            <children>
                                <Button onAction="#handleBackButton" styleClass="search-page-button" text="← Back" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label styleClass="search-section-label" text="Settings">
                                    <font>
                                        <Font size="30.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox fillWidth="true" maxWidth="1.7976931348623157E308" spacing="26.0" styleClass="search-results-box">
                            <padding>
                                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
                            </padding>

                            <children>
                                <Label styleClass="search-section-label" text="Account Information">
                                    <font>
                                        <Font size="27.0" />
                                    </font>
                                </Label>

                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0">
                                    <children>
                                        <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="search-row-label" text="First Name" />
                                                <TextField fx:id="firstNameField" maxWidth="1.7976931348623157E308" promptText="Enter first name" styleClass="search-text-field" />
                                            </children>
                                        </VBox>

                                        <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="search-row-label" text="Last Name" />
                                                <TextField fx:id="lastNameField" maxWidth="1.7976931348623157E308" promptText="Enter last name" styleClass="search-text-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0">
                                    <children>
                                        <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="search-row-label" text="Username" />
                                                <TextField fx:id="usernameField" maxWidth="1.7976931348623157E308" promptText="Enter username" styleClass="search-text-field" />
                                            </children>
                                        </VBox>

                                        <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="search-row-label" text="Email" />
                                                <TextField fx:id="emailField" maxWidth="1.7976931348623157E308" promptText="Enter email" styleClass="search-text-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Button onAction="#handleConfirmChanges" prefHeight="57.0" prefWidth="147.0" styleClass="search-page-button" text="Confirm" />

                                <Label styleClass="search-section-label" text="Security" />

                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="18.0">
                                    <children>
                                        <Button onAction="#handleResetPassword" styleClass="search-page-button" text="Reset Password" />

                                        <TextField fx:id="newPasswordField" maxWidth="1.7976931348623157E308" prefHeight="57.0" promptText="Enter New Password" styleClass="search-text-field" HBox.hgrow="ALWAYS" />

                                        <TextField fx:id="confirmPasswordField" maxWidth="1.7976931348623157E308" prefHeight="57.0" promptText="Confirm New Password" styleClass="search-text-field" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <Label fx:id="feedbackLabel" styleClass="search-row-label" text="" />

                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="18.0">
                                    <children>
                                        <Button onAction="#handleDeleteAccount" styleClass="search-page-button" text="Delete Account" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>
