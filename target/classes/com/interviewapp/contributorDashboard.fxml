                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                  </Button>
                  <Button fx:id="solutionsButton" mnemonicParsing="false" styleClass="sidebar-icon-button">
