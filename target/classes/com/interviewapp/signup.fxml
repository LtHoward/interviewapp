<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="topoverlaypane" prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.SignupController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="674.0" styleClass="createaccount-bg" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets />
         </StackPane.margin>
      </VBox>
      <Label styleClass="createaccount-label" stylesheets="@styles.css" text="Create Account" StackPane.alignment="TOP_CENTER">
         <StackPane.margin>
            <Insets top="50.0" />
         </StackPane.margin>
      </Label>
      <Button fx:id="signupbutton" mnemonicParsing="false" onAction="#handlesignup" styleClass="login-button" stylesheets="@styles.css" text="Sign up">
         <StackPane.margin>
            <Insets right="200.0" top="618.0" />
         </StackPane.margin>
      </Button>
      <Button fx:id="loginbutton" mnemonicParsing="false" onAction="#switchToLogin" styleClass="signin-button" stylesheets="@styles.css" text="Login ">
         <StackPane.margin>
            <Insets left="200.0" top="618.0" />
         </StackPane.margin>
      </Button>
      <Label fx:id="errorLabel" text="" wrapText="true" styleClass="signinlabel" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets top="540.0" />
         </StackPane.margin>
      </Label>
      <PasswordField fx:id="passwordField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="72.0" prefWidth="532.0" styleClass="signintextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets top="430.0" />
         </StackPane.margin>
      </PasswordField>
      <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="24.0" prefWidth="104.0" styleClass="signinlabel" stylesheets="@styles.css" text="Password">
         <StackPane.margin>
            <Insets right="400.0" top="314.0" />
         </StackPane.margin>
      </Label>
      <TextField fx:id="emailField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="72.0" prefWidth="532.0" styleClass="signintextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets top="170.0" />
         </StackPane.margin>
      </TextField>
      <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="24.0" prefWidth="104.0" styleClass="signinlabel" stylesheets="@styles.css" text="Email">
         <StackPane.margin>
            <Insets right="400.0" top="54.0" />
         </StackPane.margin>
      </Label>
      <TextField fx:id="usernameField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="72.0" prefWidth="532.0" styleClass="signintextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets bottom="90.0" />
         </StackPane.margin>
      </TextField>
      <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="24.0" prefWidth="104.0" styleClass="signinlabel" stylesheets="@styles.css" text="Username">
         <StackPane.margin>
            <Insets bottom="206.0" right="400.0" />
         </StackPane.margin>
      </Label>
      <TextField fx:id="firstNameField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="72.0" prefWidth="220.0" styleClass="nametextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets bottom="350.0" right="322.0" />
         </StackPane.margin>
      </TextField>
      <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="24.0" prefWidth="104.0" styleClass="signinlabel" stylesheets="@styles.css" text="First Name">
         <StackPane.margin>
            <Insets bottom="466.0" right="400.0" />
         </StackPane.margin>
      </Label>
      <TextField fx:id="lastNameField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="72.0" prefWidth="220.0" styleClass="nametextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets bottom="350.0" left="322.0" />
         </StackPane.margin>
      </TextField>
      <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="24.0" prefWidth="104.0" styleClass="signinlabel" stylesheets="@styles.css" text="Last Name">
         <StackPane.margin>
            <Insets bottom="466.0" left="244.0" />
         </StackPane.margin>
      </Label>
      <StackPane fx:id="roleoverlay" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css">
         <children>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="647.0" styleClass="createaccount-bg" stylesheets="@styles.css" />
            <Label styleClass="createaccount-label" stylesheets="@styles.css" text="What kind of account?">
               <StackPane.margin>
                  <Insets bottom="300.0" />
               </StackPane.margin>
            </Label>
            <Label styleClass="signinlabel" stylesheets="@styles.css" text="Choose the role that best describes you.">
               <StackPane.margin>
                  <Insets bottom="190.0" />
               </StackPane.margin>
            </Label>
            <ComboBox fx:id="roleComboBox" prefWidth="150.0" promptText="Select your role" styleClass="signintextfield" stylesheets="@styles.css" />
            <Button fx:id="handlecontinue" mnemonicParsing="false" onAction="#switchtonext" styleClass="login-button" stylesheets="@styles.css" text="Button">
               <StackPane.margin>
                  <Insets top="300.0" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
      <StackPane fx:id="overlaypane" prefHeight="150.0" prefWidth="200.0" styleClass="main-bg" stylesheets="@styles.css" />
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="647.0" styleClass="createaccount-bg" stylesheets="@styles.css" />
      <Label styleClass="createaccount-label" stylesheets="@styles.css" text="Academic information">
         <StackPane.margin>
            <Insets bottom="500.0" />
         </StackPane.margin>
      </Label>
      <ComboBox fx:id="majorComboBox" onAction="#handleMajor" prefWidth="150.0" styleClass="signintextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets bottom="100.0" />
         </StackPane.margin>
      </ComboBox>
      <Label styleClass="signinlabel" stylesheets="@styles.css" text="Major">
         <StackPane.margin>
            <Insets bottom="250.0" right="500.0" />
         </StackPane.margin>
      </Label>
      <ComboBox fx:id="yearComboBox" onAction="#handleYear" prefWidth="150.0" styleClass="signintextfield" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets top="200.0" />
         </StackPane.margin>
      </ComboBox>
      <Label styleClass="signinlabel" stylesheets="@styles.css" text="Year">
         <StackPane.margin>
            <Insets right="500.0" top="50.0" />
         </StackPane.margin>
      </Label>
      <Button fx:id="continuestep" mnemonicParsing="false" onAction="#switchtosignup" styleClass="login-button" stylesheets="@styles.css" text="Continue">
         <StackPane.margin>
            <Insets top="500.0" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
