<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.RoleController">
   <children>
      <HBox prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css">
         <children>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="674.0" styleClass="createaccount-bg" stylesheets="@styles.css">
               <HBox.margin>
                  <Insets left="400.0" top="25.0" />
               </HBox.margin>
               <children>
                  <Label alignment="TOP_CENTER" styleClass="createaccount-label" stylesheets="@styles.css" text="Account type?" VBox.vgrow="NEVER">
                     <VBox.margin>
                        <Insets bottom="300.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
      <ComboBox fx:id="roleComboBox" onAction="#handleComboBoxAction" prefWidth="150.0" promptText="Pick your role" styleClass="signintextfield" stylesheets="@styles.css" visibleRowCount="3">
         <StackPane.margin>
            <Insets left="30.0" />
         </StackPane.margin>
      </ComboBox>
      <Button fx:id="handlecontinue" mnemonicParsing="false" onAction="#switchtonext" styleClass="continue-button" stylesheets="@styles.css" text="Continue">
         <StackPane.margin>
            <Insets left="30.0" top="300.0" />
         </StackPane.margin>
      </Button>
      <StackPane fx:id="overlaypane" prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css">
         <children>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="674.0" styleClass="createaccount-bg" stylesheets="@styles.css" />
            <Label styleClass="createaccount-label" stylesheets="@styles.css" text="Academic Information">
               <StackPane.margin>
                  <Insets bottom="500.0" />
               </StackPane.margin>
            </Label>
            <ComboBox fx:id="majorComboBox" onAction="#handleMajor" prefWidth="150.0" styleClass="signintextfield" stylesheets="@styles.css">
               <StackPane.margin>
                  <Insets bottom="100.0" />
               </StackPane.margin>
            </ComboBox>
            <Label styleClass="login-field" stylesheets="@styles.css" text="Major">
               <StackPane.margin>
                  <Insets bottom="250.0" right="500.0" />
               </StackPane.margin>
            </Label>
            <ComboBox fx:id="yearComboBox" onAction="#handleYear" prefWidth="150.0" styleClass="signintextfield" stylesheets="@styles.css">
               <StackPane.margin>
                  <Insets top="200.0" />
               </StackPane.margin>
            </ComboBox>
            <Label styleClass="login-field" stylesheets="@styles.css" text="Year">
               <StackPane.margin>
                  <Insets right="500.0" top="50.0" />
               </StackPane.margin>
            </Label>
            <Button fx:id="continuestep" mnemonicParsing="false" onAction="#switchtosignup" styleClass="continue-button" stylesheets="@styles.css" text="Continue">
               <StackPane.margin>
                  <Insets top="500.0" />
               </StackPane.margin>
            </Button>
         </children></StackPane>
   </children>
</StackPane>
