<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="357.0" prefWidth="282.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.LoginController">
    <children>
      <Pane prefHeight="431.0" prefWidth="242.0">
         <children>
              <Label layoutX="64.0" layoutY="15.0" text="Login View" />
              <Button fx:id="back" alignment="CENTER" layoutX="14.0" layoutY="14.0" onAction="#switchToHome" prefHeight="46.0" prefWidth="41.0" text="&lt;" />
            <TextField layoutX="17.0" layoutY="144.0" />
            <TextField layoutX="17.0" layoutY="214.0" />
            <Label layoutX="12.0" layoutY="99.0" text="Username" />
            <Label layoutX="12.0" layoutY="169.0" text="Password" />
         </children>
      </Pane>
      <Button fx:id="loginButton" mnemonicParsing="false" onAction="#login" prefHeight="52.0" prefWidth="89.0" text="Login" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
</VBox>
