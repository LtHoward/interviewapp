<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="800.0" prefWidth="1440.0"
            styleClass="main-bg" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controllers.SearchController">   
   <children>
      <VBox prefHeight="800.0" prefWidth="1440.0" spacing="20.0">
         <children>
            <HBox prefHeight="61.0" prefWidth="1400.0">
               <children>
                  <Button mnemonicParsing="false" prefHeight="75.0" prefWidth="111.0"
                          styleClass="main-text" stylesheets="@styles.css"
                          text="Back"
                          onAction="#handleBack">                
                     <font><Font name="ITFDevanagari-Book" size="40.0"/></font>
                  </Button>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="89.0" prefWidth="1400.0"
                  spacing="15.0" styleClass="main-text" stylesheets="@styles.css">
               <children>
                  <Label prefHeight="37.0" prefWidth="302.0"
                         text="Search Question:" textFill="WHITE">
                     <font><Font size="40.0"/></font>
                  </Label>
                  <TextField fx:id="searchField"                 
                             prefHeight="49.0" prefWidth="688.0" HBox.hgrow="ALWAYS"/>
                  <Button mnemonicParsing="false" prefHeight="77.0" prefWidth="179.0"
                          text="search"
                          onAction="#handleSearch">              
                     <font><Font name="ITFDevanagari-Book" size="40.0"/></font>
                  </Button>
               </children>
            </HBox>

            <HBox prefHeight="90.0" prefWidth="1400.0"
                  styleClass="main-text" stylesheets="@styles.css">
               <children>
                  <Label prefHeight="90.0" prefWidth="679.0"
                         text="Suggested Questions:" textFill="WHITE">
                     <font><Font name="ITFDevanagari-Book" size="40.0"/></font>
                  </Label>
                  <Region prefHeight="90.0" prefWidth="491.0" HBox.hgrow="ALWAYS"/>
                  <Button mnemonicParsing="false" prefHeight="77.0" prefWidth="180.0"
                          text="Filter"
                          onAction="#handleFilter">              
                     <font><Font name="ITFDevanagari-Book" size="40.0"/></font>
                  </Button>
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" prefHeight="400.0" prefWidth="700.0"
                        stylesheets="@styles.css" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="resultsContainer"                 
                        prefWidth="544.0" spacing="15.0"
                        styleClass="level-card" stylesheets="@styles.css">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                     </padding>
                  </VBox>
               </content>
               <styleClass>
                  <String fx:value="left-panel"/>
                  <String fx:value="main-text"/>
               </styleClass>
            </ScrollPane>

         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
         </padding>
      </VBox>
   </children>
</AnchorPane>