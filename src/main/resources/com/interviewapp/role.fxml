<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox prefHeight="800.0" prefWidth="1440.0" styleClass="main-bg" stylesheets="@styles.css">
         <children>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="674.0" styleClass="createaccount-bg" stylesheets="@styles.css">
               <HBox.margin>
                  <Insets left="400.0" top="25.0" />
               </HBox.margin>
               <children>
                  <Label alignment="TOP_CENTER" styleClass="createaccount-label" stylesheets="@styles.css" text="Account type?" VBox.vgrow="NEVER">
                     <VBox.margin>
                        <Insets bottom="300.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
      <ComboBox fx:id="roleoption" onAction="#handleComboBoxAction" prefWidth="150.0" promptText="Pick your role" styleClass="signintextfield" stylesheets="@styles.css" visibleRowCount="3">
         <StackPane.margin>
            <Insets left="30.0" />
         </StackPane.margin>
      </ComboBox>
      <Button fx:id="handlecontinue" mnemonicParsing="false" onAction="#switchtonext" styleClass="continue-button" stylesheets="@styles.css" text="Continue">
         <StackPane.margin>
            <Insets left="30.0" top="300.0" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
