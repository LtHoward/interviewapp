<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1440.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <TextField promptText="Enter your email" styleClass="signintextfield" stylesheets="@styles.css">
               <HBox.margin>
                  <Insets left="700.0" top="400.0" />
               </HBox.margin>
            </TextField>
         </children></HBox>
      <Button fx:id="switchtonextstep" mnemonicParsing="false" onAction="#handlecontinue" styleClass="continue-button" stylesheets="@styles.css" text="continue">
         <StackPane.margin>
            <Insets left="500.0" top="300.0" />
         </StackPane.margin>
      </Button>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="770.0" prefWidth="480.0" styleClass="left-panel" stylesheets="@styles.css">
         <StackPane.margin>
            <Insets right="920.0" />
         </StackPane.margin>
      </VBox>
      <Label styleClass="main-text" stylesheets="@styles.css" text="Reset  your password">
         <StackPane.margin>
            <Insets bottom="500.0" right="970.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-text" stylesheets="@styles.css" text="Create a new password">
         <StackPane.margin>
            <Insets bottom="300.0" right="950.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="sub-to-main-text" stylesheets="@styles.css" text="Must be a valid email.">
         <StackPane.margin>
            <Insets bottom="450.0" right="970.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-sub-text" stylesheets="@styles.css" text="Must be at least 8 characters.">
         <StackPane.margin>
            <Insets bottom="250.0" right="900.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-text" stylesheets="@styles.css" text="Confirm new password">
         <StackPane.margin>
            <Insets bottom="100.0" right="960.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-sub-text" stylesheets="@styles.css" text="Enter your new password.">
         <StackPane.margin>
            <Insets bottom="50.0" right="940.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-text" stylesheets="@styles.css" text="Password reset!">
         <StackPane.margin>
            <Insets right="1020.0" top="100.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="unhighlighted-sub-text" stylesheets="@styles.css" text="Success! Click to log in.">
         <StackPane.margin>
            <Insets right="960.0" top="150.0" />
         </StackPane.margin>
      </Label>
      <Button fx:id="backtologin" mnemonicParsing="false" onAction="#switchtologin" styleClass="text-button" stylesheets="@styles.css" text="Back to log in">
         <StackPane.margin>
            <Insets right="970.0" top="700.0" />
         </StackPane.margin>
      </Button>
      <Label styleClass="createaccount-label" stylesheets="@styles.css" text="Reset your password">
         <StackPane.margin>
            <Insets bottom="350.0" left="500.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="sub-text-reset" stylesheets="@styles.css" text="Forgot password?">
         <StackPane.margin>
            <Insets bottom="200.0" left="500.0" />
         </StackPane.margin>
      </Label>
      <Label styleClass="sub-text-reset" stylesheets="@styles.css" text="Please enter in your valid email.">
         <StackPane.margin>
            <Insets bottom="150.0" left="500.0" />
         </StackPane.margin>
      </Label>
   </children>
</StackPane>
