<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1440.0"
            styleClass="main-bg"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controllers.ProfileController">
   <children>
      <VBox alignment="CENTER" layoutX="127.0" layoutY="97.0" prefHeight="744.0" prefWidth="1300.0" spacing="20.0" styleClass="main-text" stylesheets="@styles.css" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="35.0">
         <padding>
            <Insets top="20.0" />
         </padding>
         <children>
            <StackPane prefHeight="150.0" prefWidth="200.0">
               <children>
                  <ImageView fitHeight="220.0" fitWidth="1300.0" pickOnBounds="true" preserveRatio="false">
                     <image>
                        <Image url="@images/banner1.png" />
                     </image>
                  </ImageView>
                  <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <StackPane prefHeight="150.0" prefWidth="200.0">
                           <children>
                              <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/DefaultIcon.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" prefHeight="150.0" prefWidth="250.0" spacing="6.0">
                           <children>
                              <Label fx:id="usernameLabel" styleClass="white-text" stylesheets="@styles.css" text="Username" />
                              <Label fx:id="roleLabel" styleClass="white-text" stylesheets="@styles.css" text="Role / Major" />
                              <Label fx:id="nameLabel" styleClass="white-text" stylesheets="@styles.css" text="Equipped Title / Name" />
                           </children>
                        </VBox>
                        <Region prefHeight="180.0" prefWidth="0.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleEditProfile" stylesheets="@styles.css" text="Edit Profile" />
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
                     </padding>
                  </HBox>
               </children>
            </StackPane>

            <VBox prefHeight="46.0" prefWidth="1400.0" spacing="15.0">
               <padding>
                  <Insets top="20.0" />
               </padding>
               <children>
                  <HBox prefHeight="10.0" prefWidth="1400.0">
                     <children>
                        <Label styleClass="white-text" text="About" />
                        <Region prefHeight="43.0" prefWidth="1155.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleEditAbout" text="Edit" />
                     </children>
                  </HBox>
                  <HBox prefHeight="29.0" prefWidth="1400.0">
                     <children>
                        <Label fx:id="aboutLabel" styleClass="white-text" stylesheets="@styles.css" text="About text" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox layoutX="10.0" layoutY="150.0" prefHeight="49.0" prefWidth="1400.0" spacing="15.0">
               <padding>
                  <Insets top="20.0" />
               </padding>
               <children>
                  <HBox prefHeight="100.0" prefWidth="1400.0">
                     <children>
                        <Label styleClass="white-text" stylesheets="@styles.css" text="Achievements" />
                        <Region prefHeight="100.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleEditAchievements" stylesheets="@styles.css" text="Edit" />
                     </children>
                  </HBox>
                  <HBox prefHeight="29.0" prefWidth="1400.0">
                     <children>
                        <Label fx:id="achievementsLabel" styleClass="white-text" text="Achievements text" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox layoutX="10.0" layoutY="248.0" prefHeight="49.0" prefWidth="1400.0" spacing="15.0">
               <padding>
                  <Insets top="20.0" />
               </padding>
               <children>
                  <HBox prefHeight="100.0" prefWidth="1400.0">
                     <children>
                        <Label styleClass="white-text" stylesheets="@styles.css" text="Skills" />
                        <Region prefHeight="100.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleEditSkills" stylesheets="@styles.css" text="Edit" />
                     </children>
                  </HBox>
                  <HBox prefHeight="29.0" prefWidth="1400.0">
                     <children>
                        <Label fx:id="skillsLabel" styleClass="white-text" stylesheets="@styles.css" text="Skills text" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox layoutX="10.0" layoutY="346.0" prefHeight="49.0" prefWidth="1400.0" spacing="15.0">
               <padding>
                  <Insets top="20.0" />
               </padding>
               <children>
                  <HBox prefHeight="100.0" prefWidth="1400.0">
                     <children>
                        <Label styleClass="white-text" stylesheets="@styles.css" text="Stats" />
                        <Region prefHeight="100.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleEditStatistics" stylesheets="@styles.css" text="Edit" />
                     </children>
                  </HBox>
                  <HBox prefHeight="29.0" prefWidth="1400.0">
                     <children>
                        <Label fx:id="statisticsLabel" styleClass="white-text" stylesheets="@styles.css" text="Stats text" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>

      <Button alignment="BOTTOM_LEFT"
              layoutX="6.0" layoutY="11.0"
              mnemonicParsing="false"
              onAction="#handleBack"
              prefHeight="21.0" prefWidth="46.0"
              stylesheets="@styles.css"
              text="Back" />
   </children>
</AnchorPane>